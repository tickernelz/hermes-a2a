# Profile-local A2A configuration example.
# Put this in the target profile config.yaml, not in a sibling profile.

plugins:
  enabled:
    - a2a

platform_toolsets:
  discord:
    - hermes-discord
    - a2a

known_plugin_toolsets:
  discord:
    - a2a

a2a:
  enabled: true
  server:
    host: 127.0.0.1
    port: 41731
    public_url: http://127.0.0.1:41731
    require_auth: true
  security:
    allow_unconfigured_urls: false
    redact_outbound: true
    max_message_chars: 50000
    max_response_chars: 100000
    max_request_bytes: 1048576
    max_raw_part_bytes: 262144
    max_parts: 20
    rate_limit_per_minute: 20
  agents:
    - name: reviewer_agent
      url: http://127.0.0.1:41732
      description: Local reviewer Hermes profile
      auth_token_env: A2A_AGENT_REVIEWER_TOKEN
      enabled: true
      tags: [local, reviewer]
      trust_level: trusted

webhook:
  enabled: true
  extra:
    port: 47644
    routes:
      a2a_trigger:
        secret: <same random value as A2A_WEBHOOK_SECRET in .env>
        deliver: discord
        deliver_extra:
          chat_id: '<discord-chat-id>'
        prompt: '[A2A trigger]'
        source:
          platform: discord
          chat_type: group
          chat_id: '<discord-chat-id>'
          user_id: '<discord-user-id>'
          user_name: '<display-name>'

# Note: Hermes webhook validation reads the route secret from config.yaml,
# while the A2A plugin uses A2A_WEBHOOK_SECRET from .env when signing the
# internal wake request. They must match exactly.

platforms:
  webhook:
    enabled: true
    extra:
      port: 47644
      routes:
        a2a_trigger:
          secret: <same random value as A2A_WEBHOOK_SECRET in .env>
          deliver: discord
          deliver_extra:
            chat_id: '<discord-chat-id>'
          prompt: '[A2A trigger]'
          source:
            platform: discord
            chat_type: group
            chat_id: '<discord-chat-id>'
            user_id: '<discord-user-id>'
            user_name: '<display-name>'

# Matching .env values for this profile:
# A2A_ENABLED=true
# A2A_HOST=127.0.0.1
# A2A_PORT=41731
# A2A_PUBLIC_URL=http://127.0.0.1:41731
# A2A_REQUIRE_AUTH=true
# A2A_AUTH_TOKEN=<secret for inbound calls to this profile>
# A2A_WEBHOOK_SECRET=<secret used by webhook route>
# A2A_AGENT_REVIEWER_TOKEN=<secret expected by reviewer_agent>
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=47644
